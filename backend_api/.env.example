# This file serves as an example for the required environment variables.
# Copy this file to .env and replace the placeholder values with your actual credentials.

# -- PostgreSQL Database --
# Used by various services for operational data, alerts, cases, etc.
DB_HOST=postgres
DB_PORT=5432
DB_USER=phantomnet
DB_PASSWORD=YOUR_POSTGRES_PASSWORD
DB_NAME=phantomnet_db

# -- Neo4j Graph Database --
# Used by the Attack Graph and Graph Intelligence services.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

# -- JWT (JSON Web Token) --
# Critical for securing API endpoints and managing user sessions.
# Use a long, random, and unpredictable string.
JWT_SECRET_KEY=YOUR_SUPER_SECRET_JWT_KEY

# -- Redis --
# Used for caching, rate limiting, and message bus functionalities.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# -- Kafka / Redpanda --
# The primary message bus for event streaming between services.
KAFKA_BOOTSTRAP_SERVERS=redpanda:29092

# -- Application Environment --
# Set to "production" for production deployments to enforce stricter security.
# Set to "development" for local development.
ENVIRONMENT=development
