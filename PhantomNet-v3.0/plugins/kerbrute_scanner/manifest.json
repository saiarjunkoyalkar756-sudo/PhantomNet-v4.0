{
    "name": "Kerbrute Scanner",
    "version": "1.0.0",
    "description": "A plugin to perform Kerbrute-like brute-force enumeration on Active Directory.",
    "author": "PhantomNet Contrib",
    "entry_point": "kerbrute_entry.py",
