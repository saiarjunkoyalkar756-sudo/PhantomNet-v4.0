{
    "name": "Example Scanner Plugin",
    "version": "0.1.0",
    "description": "A basic example plugin demonstrating a new scanner integration.",
    "author": "PhantomNet Team",
    "entry_point": "entry.py",
    "type": "scanner",
    "dependencies": [
        "scapy",
        "python-nmap"
    ],
    "permissions": [
        "network_access:scan",
        "file_system:read_only",
        "system_command:limited"
    ],
    "sandbox_config": {
        "isolation_level": "medium",
        "resource_limits": {
            "cpu_shares": 512,
            "memory_mb": 256
        }
    }
}
