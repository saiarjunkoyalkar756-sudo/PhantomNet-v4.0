# .env.example
# PhantomNet v3.0 Environment Configuration
# Copy this file to .env and fill in the values

# --- CORE SETTINGS ---
# Environment: development | staging | production
ENVIRONMENT=development
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- DATABASE (PostgreSQL) ---
# Async connection string for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://phantomnet:changeme@localhost:5432/phantomnet
# Password used by Docker Compose to initialize Postgres
DB_PASSWORD=changeme

# --- CACHE & BUS (Redis) ---
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# --- STREAMING (Kafka) ---
# Kafka bootstrap servers (comma-separated)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- SECURITY (JWT) ---
# Secret key for signing tokens (change in production!)
JWT_SECRET_KEY=changeme-replace-in-production-with-64-char-hex
# JWT Algorithm
JWT_ALGORITHM=HS256
# Token expiration in minutes
JWT_EXPIRE_MINUTES=60

# --- THREAT INTELLIGENCE (OSINT) ---
# VirusTotal API Key (Optional)
VIRUSTOTAL_API_KEY=
# MISP Instance URL
MISP_URL=
# MISP API Key
MISP_KEY=
# AbuseIPDB API Key (Optional)
ABUSEIPDB_API_KEY=

# --- COMMUNICATIONS (SMTP/SendGrid) ---
# SendGrid API Key (Optional)
SENDGRID_API_KEY=
# SMTP Settings
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=

# --- AI & LLM ---
# Ollama base URL (default for local fallback)
OLLAMA_BASE_URL=http://localhost:11434
# OpenAI API Key (Optional)
OPENAI_API_KEY=

# --- PAYMENTS (Stripe) ---
# Stripe Secret Key (Optional)
STRIPE_SECRET_KEY=
# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET=

# --- BLOCKCHAIN ---
# Blockchain mode: mock | local | mainnet
BLOCKCHAIN_MODE=mock

# --- INITIAL ADMIN ---
# Initial admin internal email
ADMIN_EMAIL=admin@phantomnet.local
# Initial admin password
ADMIN_PASSWORD=changeme

# --- RED TEAMING ---
# Confirmation token required when SIMULATION_MODE=False
RED_TEAM_CONFIRM_TOKEN=danger-zone-confirm
