# .env.example
# This file serves as a template for your .env file.
# COPY THIS FILE TO .env AND FILL IN YOUR SECRETS.
# DO NOT COMMIT YOUR .env FILE TO VERSION CONTROL!

# --- CORE APPLICATION SETTINGS ---
# Set the environment (development, production, testing)
ENVIRONMENT=development

# --- JWT SECRET KEY ---
# A strong, randomly generated key for signing JWTs.
# Must be kept secret. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=YOUR_SUPER_SECRET_JWT_KEY_CHANGE_ME_IMMEDIATELY_IN_PRODUCTION

# JWT Algorithm (default: HS256)
JWT_ALGORITHM=HS256

# JWT Access Token Expiration (in minutes, default: 30)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- DATABASE SECRETS (PostgreSQL) ---
# Strong passwords for your PostgreSQL instance.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
DB_PASSWORD=changeme_db_password

# Database connection details for local setup (e.g., for Alembic or non-Docker demo)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phantomnet_db
DB_USER=phantomnet

# --- NEO4J SECRETS ---
# Strong password for your Neo4j instance.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
NEO4J_PASSWORD=changeme_neo4j_password

# --- REDIS PASSWORD ---
# Password for your Redis instance. Can be empty if Redis is not protected.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
REDIS_PASSWORD=

# --- THREAT INTELLIGENCE API KEYS ---
# API keys for external Threat Intelligence services.
# These are optional, but required for full functionality of the TI service.
# VIRUSTOTAL_API_KEY=your_virustotal_api_key
# ALIENVAULT_OTX_API_KEY=your_alienvault_otx_api_key
# ABUSEIPDB_API_KEY=your_abuseipdb_api_key
# SHODAN_API_KEY=your_shodan_api_key
# CENSYS_API_ID=your_censys_api_id
# CENSYS_API_SECRET=your_censys_api_secret

# --- NVD API KEY (for CVE Resolver) ---
# NVD API Key (optional, for higher rate limits and specific endpoints)
# NVD_API_KEY=your_nvd_api_key

# --- ORCHESTRATOR API URL ---
# URL for the Orchestrator API endpoint for agent commands.
# ORCHESTRATOR_API_URL=http://localhost:8000/orchestrator (default if not set)

# --- AGENT MANAGER URL ---
# URL where the agent can register and communicate with the backend.
# AGENT_MANAGER_URL=http://localhost:8000 (default if not set)

# --- GEOLOCATION API KEY (Optional, if using a paid service for higher limits) ---
# The default uses ip-api.com which has rate limits.
# GEOLOCATION_API_KEY=your_geolocation_api_key

# --- RABBITMQ (SOAR Engine) ---
# Hostname for RabbitMQ. Required if SOAR engine is enabled.
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
